    },
    "relationships": [
      "Each Employee belongs to a department and has a primary reporting manager (another Employee)",
      "Each Employee may have a secondary reporting manager for dotted-line reporting",
      "Employees can be members of one or more Teams",
      "Each Team has one designated team lead (an Employee)",
      "Each Employee has a unique permissions configuration controlling their system access"
    ]
  },
