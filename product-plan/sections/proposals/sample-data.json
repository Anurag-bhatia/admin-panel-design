{
  "_meta": {
    "models": {
      "proposals": "A customer service request for challan resolution, DL verification, or RC verification. Each proposal moves through a lifecycle from inbox to review, quoting, and finally conversion to an incident or rejection.",
      "proposalItems": "The individual items within a proposal — specific challans, driving licences, or registration certificates that need processing.",
      "activities": "Audit trail entries that record every status change, assignment, quote action, and note on a proposal.",
      "comments": "Messages in the shared notes thread between the customer and the admin team. Both sides see the same thread.",
      "teamMembers": "Internal LOTS team staff who can be assigned to review and manage proposals."
    },
    "relationships": [
      "Each Proposal belongs to a Customer (tracked via the customer object on the proposal)",
      "Each Proposal may be assigned to a TeamMember",
      "Each Proposal contains one or more ProposalItems (the specific challans, DLs, or RCs)",
      "Each Proposal has many Activities (the audit timeline)",
      "Each Proposal has many Comments (the shared chat thread)",
      "A converted Proposal links to an Incident via linkedIncidentId"
    ]
  },
